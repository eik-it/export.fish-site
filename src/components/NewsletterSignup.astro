---
interface Props {
  variant?: 'compact' | 'full';
}

const { variant = 'full' } = Astro.props;

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
const apiBaseUrl = import.meta.env.PUBLIC_API_BASE_URL ?? 'https://api.eksportfiske.no';

const isCompact = variant === 'compact';
---

<div
  class:list={[
    'newsletter-signup',
    isCompact
      ? 'newsletter-signup--compact'
      : 'newsletter-signup--full bg-white rounded-2xl shadow-lg border border-gray-200 p-8 md:p-12',
  ]}
  data-api-base={apiBaseUrl}
>
  {isCompact ? (
    <div>
      <p class="text-sm font-semibold text-white mb-3">Nyhetsbrev</p>
      <form class="newsletter-form flex flex-col sm:flex-row gap-2" novalidate>
        <input
          type="email"
          name="email"
          placeholder="Din e-postadresse"
          required
          autocomplete="email"
          class="flex-1 px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 text-white placeholder-gray-400 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
        />
        <button
          type="submit"
          class="newsletter-submit px-4 py-2 bg-primary hover:bg-primary-hover text-white text-sm font-semibold rounded-lg transition-colors whitespace-nowrap disabled:opacity-60 disabled:cursor-not-allowed"
        >
          Meld meg på
        </button>
      </form>
      <div class="newsletter-feedback mt-2 text-sm hidden"></div>
    </div>
  ) : (
    <div>
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <div>
          <h2 class="text-xl font-semibold text-gray-900">Nyhetsbrev fra Eksportfiske</h2>
          <p class="text-sm text-gray-500">Regelendringer, tips og nye funksjoner rett i innboksen</p>
        </div>
      </div>

      <form class="newsletter-form space-y-4" novalidate>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="newsletter-email" class="block text-sm font-medium text-gray-700 mb-1">
              E-postadresse <span class="text-red-500" aria-hidden="true">*</span>
            </label>
            <input
              type="email"
              id="newsletter-email"
              name="email"
              placeholder="din@epost.no"
              required
              autocomplete="email"
              class="w-full px-4 py-2.5 rounded-lg border border-gray-300 text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
            />
          </div>
          <div>
            <label for="newsletter-name" class="block text-sm font-medium text-gray-700 mb-1">
              Navn <span class="text-gray-400 font-normal">(valgfritt)</span>
            </label>
            <input
              type="text"
              id="newsletter-name"
              name="name"
              placeholder="Ditt navn"
              autocomplete="name"
              class="w-full px-4 py-2.5 rounded-lg border border-gray-300 text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
            />
          </div>
        </div>

        {turnstileSiteKey && (
          <div class="newsletter-turnstile" id={`newsletter-turnstile-${variant}`}>
            <div
              class="cf-turnstile"
              data-sitekey={turnstileSiteKey}
              data-theme="light"
            ></div>
          </div>
        )}

        <button
          type="submit"
          class="newsletter-submit w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3 bg-primary hover:bg-primary-hover text-white font-semibold rounded-lg transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
        >
          <svg class="w-4 h-4 newsletter-submit-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <span class="newsletter-submit-text">Meld meg på</span>
        </button>
      </form>

      <div class="newsletter-feedback mt-4 hidden"></div>
    </div>
  )}
</div>

{turnstileSiteKey && variant === 'full' && (
  <script
    src="https://challenges.cloudflare.com/turnstile/v0/api.js"
    async
    defer
  ></script>
)}

<script>
  document.querySelectorAll<HTMLElement>('.newsletter-signup').forEach((widget) => {
    const form = widget.querySelector<HTMLFormElement>('.newsletter-form');
    const feedback = widget.querySelector<HTMLElement>('.newsletter-feedback');
    const submitBtn = widget.querySelector<HTMLButtonElement>('.newsletter-submit');
    const submitText = widget.querySelector<HTMLElement>('.newsletter-submit-text');
    const apiBase = widget.dataset.apiBase ?? 'https://api.eksportfiske.no';

    if (!form || !feedback || !submitBtn) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const emailInput = form.querySelector<HTMLInputElement>('input[name="email"]');
      const nameInput = form.querySelector<HTMLInputElement>('input[name="name"]');

      if (!emailInput?.value) {
        showFeedback('Vennligst oppgi e-postadresse.', 'error');
        emailInput?.focus();
        return;
      }

      // Turnstile token (graceful if not present)
      let captchaToken = '';
      const turnstileWidget = widget.querySelector<HTMLElement>('.cf-turnstile');
      if (turnstileWidget && (window as any).turnstile) {
        captchaToken = (window as any).turnstile.getResponse(turnstileWidget) ?? '';
      }

      setLoading(true);

      try {
        const body: Record<string, string> = {
          email: emailInput.value.trim(),
          captchaToken,
        };
        const name = nameInput?.value?.trim();
        if (name) body.name = name;

        const response = await fetch(`${apiBase}/v1/newsletter/subscribe`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });

        if (response.ok) {
          showFeedback('Sjekk e-posten din for å bekrefte påmeldingen.', 'success');
          form.reset();
          if ((window as any).turnstile && turnstileWidget) {
            (window as any).turnstile.reset(turnstileWidget);
          }
        } else {
          showFeedback('Noe gikk galt, prøv igjen.', 'error');
          if ((window as any).turnstile && turnstileWidget) {
            (window as any).turnstile.reset(turnstileWidget);
          }
        }
      } catch {
        showFeedback('Noe gikk galt, prøv igjen.', 'error');
      } finally {
        setLoading(false);
      }
    });

    function setLoading(loading: boolean) {
      submitBtn!.disabled = loading;
      if (submitText) {
        submitText.textContent = loading ? 'Sender...' : 'Meld meg på';
      } else {
        submitBtn!.textContent = loading ? 'Sender...' : 'Meld meg på';
      }
    }

    function showFeedback(message: string, type: 'success' | 'error') {
      if (!feedback) return;
      feedback.textContent = message;
      feedback.className = [
        'newsletter-feedback',
        'mt-2',
        'text-sm',
        'rounded-lg',
        'px-4',
        'py-2',
        type === 'success'
          ? 'bg-green-50 text-green-700 border border-green-200'
          : 'bg-red-50 text-red-700 border border-red-200',
      ].join(' ');
      feedback.classList.remove('hidden');
    }
  });
</script>
