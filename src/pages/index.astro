---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

// Import hero and feature images
import heroBg from '../assets/hero-bg.jpg';
import feature1 from '../assets/feature-1.jpg';
import feature2 from '../assets/feature-2.jpg';
import feature3 from '../assets/feature-3.jpg';
import appScreenshot from '../assets/app-screenshot.png';

// Import fish species images
import torsk from '../assets/torsk.png';
import kveite from '../assets/kveite.png';
import uer from '../assets/uer.png';
import steinbit from '../assets/steinbit.png';
import sei from '../assets/sei.png';

// Import logo
import logo from '../assets/logo.png';
---

<Layout
  title="Må du registrere turistfiskebedrift? Lovpålagt fangstrapportering for fritidsboligeiere"
  description="Utleie av hytte med båt til turistfiskere? Sjekk reglene for fangstrapportering. Tyskere og andre turister kan eksportere fisk fra Norge med riktig dokumentasjon. Unngå bøter ."
>

  <!-- Hero Section -->
  <section class="relative pt-52 pb-32 md:pb-40 text-white overflow-hidden" aria-labelledby="hero-heading">
    <!-- Background Image -->
    <div class="absolute inset-0 opacity-0 transition-opacity duration-1000 ease-out hero-bg-loaded" aria-hidden="true">
      <Image src={heroBg} alt="" class="w-full h-full object-cover" widths={[640, 1024, 1280, 1920]} sizes="100vw" loading="eager" fetchpriority="high" />
      <div class="absolute inset-0 bg-gradient-to-br from-blue-400/75 via-blue-500/80 to-blue-600/85"></div>
    </div>

    <div class="w-full mx-auto text-center max-w-5xl relative z-10 px-4">
      <h1 class="text-4xl md:text-7xl font-bold mb-6 leading-tight break-words" id="hero-heading">
        Leier du ut <span
          id="hero-word"
          style="display:inline-block;transition:opacity 0.18s ease,transform 0.18s ease;will-change:opacity,transform;"
        >hytta</span> til turistfiskere?
      </h1>

      <p class="text-xl md:text-2xl mb-10 max-w-3xl mx-auto text-blue-50 font-light leading-relaxed">
        Da må du rapportere fangst til Fiskeridirektoratet. Vi gjør det enkelt – turistene registrerer selv på sitt språk.
      </p>

      <!-- Trust Signal Badge -->
      <div class="mb-6 inline-flex items-center gap-2 bg-green-500/20 border border-green-400/40 rounded-full px-4 py-2">
        <svg class="w-5 h-5 text-green-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
        </svg>
        <span class="text-sm font-semibold text-green-100">Godkjent rapporteringssystem fra Fiskeridirektoratet</span>
      </div>

      <div class="mb-8 flex flex-wrap justify-center gap-6 text-sm text-blue-100">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-white" viewBox="0 0 20 20" fill="currentColor">
            <path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" fill-rule="evenodd"></path>
          </svg>
          <span>Ingen installasjon</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-white" viewBox="0 0 20 20" fill="currentColor">
            <path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" fill-rule="evenodd"></path>
          </svg>
          <span>Flerspråklig: 🇳🇴 · 🇬🇧 · 🇩🇪</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-white" viewBox="0 0 20 20" fill="currentColor">
            <path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" fill-rule="evenodd"></path>
          </svg>
          <span>Kun 82,50 kr/mnd*</span>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center max-w-full w-full">
        <a
          class="relative overflow-hidden bg-white text-blue-900 hover:bg-blue-50 font-semibold text-base sm:text-lg px-6 sm:px-8 py-3 sm:py-4 rounded-lg transition-all transform hover:scale-105 shadow-xl text-center"
          href="/registrer"
        >
          <span class="relative z-10">Bestill nå</span>
        </a>
        <a
          class="bg-transparent hover:bg-white/10 text-white font-semibold text-base sm:text-lg px-6 sm:px-8 py-3 sm:py-4 rounded-lg border-2 border-white/30 transition-colors text-center"
          href="https://test.export.fish"
          rel="noopener noreferrer"
          target="_blank"
        >
          Test vår løsning
        </a>
      </div>
          </div>

    <!-- Wave Divider -->
    <div class="absolute -bottom-px left-0 w-full">
      <svg class="w-full h-auto" viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0,64L48,69.3C96,75,192,85,288,80C384,75,480,53,576,48C672,43,768,53,864,58.7C960,64,1056,64,1152,58.7C1248,53,1344,43,1392,37.3L1440,32L1440,120L1392,120C1344,120,1248,120,1152,120C1056,120,960,120,864,120C768,120,672,120,576,120C480,120,384,120,288,120C192,120,96,120,48,120L0,120Z" fill="#F9FAFB"/>
      </svg>
    </div>
  </section>

  <!-- Om oss teaser -->
  <section class="py-10 bg-gray-50">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <p class="text-lg text-gray-700 leading-relaxed mb-6">
        Eksportfiske.no ble til fordi jeg selv sto uten et godt svar da en tysk gjest spurte om fangstrapportering og eksportdokumentasjon. Jeg lette etter en enkel, godkjent løsning — og fant ingen. Så bygde jeg den. Laget av en utleier, for andre utleiere.
      </p>
      <a
        href="/om-oss"
        class="inline-flex items-center gap-2 text-primary hover:text-primary-hover font-semibold transition-colors group"
      >
        Les historien bak
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </section>

  <!-- Features Section -->
  <section id="fordeler" class="py-20 bg-gray-50 px-4">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-4xl font-bold text-center text-gray-900 mb-4">Hvorfor velge vår appløsning?</h2>
      <p class="text-xl text-gray-600 text-center mb-16 max-w-2xl mx-auto">
        Enkel løsning for turistfiskebedrifter i hele Norge for daglig fangstrapportering
      </p>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Feature 1 -->
        <article class="group bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition-all duration-300 transform hover:scale-105">
          <div class="h-48 relative overflow-hidden">
            <Image src={feature3} alt="Turistfiskebåt ved norsk fjord - fangstrapportering eksportfiske.no" class="w-full h-full object-cover" width={800} height={600} />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-black/20"></div>
          </div>
          <div class="p-6">
            <h3 class="text-2xl font-bold mb-3 text-gray-900">Spar tid hver uke</h3>
            <p class="text-gray-600 leading-relaxed">
              Appen forenkler rapporteringen – turistene registrerer fangsten selv, mens du beholder oversikt og ansvar som turistfiskebedrift.
            </p>
          </div>
        </article>

        <!-- Feature 2 -->
        <article class="group bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition-all duration-300 transform hover:scale-105">
          <div class="h-48 relative overflow-hidden">
            <Image src={feature1} alt="Turistfiske opplevelse med digital fangstrapportering" class="w-full h-full object-cover" width={800} height={600} />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-black/20"></div>
          </div>
          <div class="p-6">
            <h3 class="text-2xl font-bold mb-3 text-gray-900">Aldri mer bekymring for fangstregistrering</h3>
            <p class="text-gray-600 leading-relaxed">
              Godkjent rapporteringssystem som automatisk sender all nødvendig informasjon til Fiskeridirektoratet.
            </p>
          </div>
        </article>

        <!-- Feature 3 -->
        <article class="group bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition-all duration-300 transform hover:scale-105">
          <div class="h-48 relative overflow-hidden">
            <Image src={feature2} alt="Fornøyde fisketurister bruker export.fish rapporteringsapp" class="w-full h-full object-cover" width={800} height={600} />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-black/20"></div>
          </div>
          <div class="p-6">
            <h3 class="text-2xl font-bold mb-3 text-gray-900">Fornøyde turister</h3>
            <p class="text-gray-600 leading-relaxed">
              De setter pris på det profesjonelle uttrykket og at de får all eksportdokumentasjon i orden for utførsel av fisk.
            </p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Slik hjelper appen vår din virksomhet -->
  <section class="py-16 px-4 bg-gradient-to-br from-green-50 to-emerald-50">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-10">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-green-100 rounded-full mb-4">
          <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
          </svg>
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Slik hjelper appen vår din virksomhet</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Alt du trenger for å oppfylle de nye 2025-kravene – automatisk og uten ekstra arbeid
        </p>
      </div>

      <div class="bg-white rounded-2xl shadow-xl p-8 md:p-10">
        <ul class="space-y-5">
          <li class="flex items-start gap-4">
            <div class="flex-shrink-0 w-8 h-8 bg-green-100 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-gray-900 text-lg">Daglig fangstrapportering i appen</p>
              <p class="text-gray-600">Oppfyller det nye kravet om daglig rapportering fra august 2025</p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <div class="flex-shrink-0 w-8 h-8 bg-green-100 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-gray-900 text-lg">Utsteder godkjent eksportdokumentasjon med alle lovpålagte felt</p>
              <p class="text-gray-600">Turistene får dokumentene de trenger for å ta med fisk hjem</p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <div class="flex-shrink-0 w-8 h-8 bg-green-100 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-gray-900 text-lg">Sikrer at du følger rapporteringskrav FØR dokumentutstedelse</p>
              <p class="text-gray-600">Det nye regelverket krever rapportering før du kan utstede dokumenter</p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <div class="flex-shrink-0 w-8 h-8 bg-green-100 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-gray-900 text-lg">Turistene registrerer fangsten selv</p>
              <p class="text-gray-600">Du slipper manuelt arbeid – gjestene gjør jobben direkte i appen</p>
            </div>
          </li>
          </ul>
      </div>
    </div>
  </section>

  <!-- App Preview Section -->
  <section class="py-12 sm:py-16 md:py-20 bg-gradient-to-br from-gray-50 to-primary-light">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
        <div>
          <h2 class="text-3xl sm:text-4xl font-bold mb-4 sm:mb-6">Appen som gjør rapportering enkelt</h2>
          <p class="text-lg sm:text-xl text-gray-600 mb-6">
            export.fish er en moderne PWA (Progressive Web App) som fungerer på alle enheter uten nedlasting fra app-butikk. Turistene får tilgang via e-post og kan registrere fangst selv.
          </p>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <div class="flex-shrink-0 w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
                </svg>
              </div>
              <div>
                <strong class="block text-lg text-gray-900">Fungerer på mobil, nettbrett og PC</strong>
                <span class="text-gray-600">Tilgjengelig på alle enheter med nettleser</span>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="flex-shrink-0 w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                </svg>
              </div>
              <div>
                <strong class="block text-lg text-gray-900">Ingen installasjon nødvendig</strong>
                <span class="text-gray-600">Åpnes direkte i nettleseren - ingen app-butikk</span>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="flex-shrink-0 w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
              </div>
              <div>
                <strong class="block text-lg text-gray-900">E-post-basert tilgang</strong>
                <span class="text-gray-600">Ingen passord å huske - tilgang via unik lenke</span>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="flex-shrink-0 w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"></path>
                </svg>
              </div>
              <div>
                <strong class="block text-lg text-gray-900">Tilgjengelig på norsk, engelsk og tysk</strong>
                <span class="text-gray-600">Turistene bruker appen på sitt eget språk</span>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="flex-shrink-0 w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div>
                <strong class="block text-lg text-gray-900">Validering som sikrer korrekt rapportering</strong>
                <span class="text-gray-600">Innebygde kontroller og veiledning minimerer feil i fangstregistreringen</span>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="flex-shrink-0 w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div>
                <strong class="block text-lg text-gray-900">Enkelt å bruke</strong>
                <span class="text-gray-600">Intuitiv og brukervennlig – krever ingen opplæring</span>
              </div>
            </li>
          </ul>
        </div>
        <div class="relative mt-8 md:mt-0">
          <!-- Phone Mockup -->
          <div class="relative mx-auto w-[240px] sm:w-[280px] md:w-[320px]">
            <!-- Phone Frame -->
            <div class="relative bg-gray-900 rounded-[3rem] p-3 shadow-2xl">
              <div class="bg-white rounded-[2.5rem] overflow-hidden">
                <!-- App Screenshot -->
                <div class="aspect-[9/19] bg-white flex items-start justify-center">
                  <Image
                    src={appScreenshot}
                    alt="export.fish app screenshot"
                    class="w-full h-auto object-contain"
                    width={320}
                    height={676}
                  />
                </div>
              </div>
            </div>
            <!-- Decorative elements -->
            <div class="absolute -z-10 -top-4 -right-4 w-24 h-24 bg-primary-pale rounded-full blur-3xl opacity-50"></div>
            <div class="absolute -z-10 -bottom-4 -left-4 w-32 h-32 bg-primary-pale rounded-full blur-3xl opacity-50"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-16 px-4 bg-white border-y border-gray-200">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-3 gap-8 text-center">
        <div>
          <div class="text-4xl font-bold text-primary mb-2">100%</div>
          <div class="text-gray-600">Oppfyller Fiskeridirektoratets krav</div>
        </div>
        <div>
          <div class="text-4xl font-bold text-primary mb-2">3</div>
          <div class="text-sm text-gray-600">Språk støttet<br />🇳🇴 · 🇬🇧 · 🇩🇪</div>
        </div>
        <div>
          <div class="text-4xl font-bold text-primary mb-2">82,50 / mnd*</div>
          <div class="text-gray-600">Per turistfiskebedrift (eks. mva)<br/><span class="text-xs">*Faktureres årlig: 990,- kr</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section id="hvordan-virker-det" class="py-20 px-4 bg-gradient-to-br from-blue-50 to-blue-100">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-4xl font-bold text-center text-gray-900 mb-12">Hvordan virker det?</h2>

      <!-- For bedriften -->
      <div class="mb-16">
        <h3 class="text-2xl font-bold text-center text-gray-800 mb-8">For bedriften</h3>
        <div class="bg-white rounded-2xl shadow-lg p-8 max-w-3xl mx-auto space-y-4">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-12 h-12 bg-primary text-white rounded-full flex items-center justify-center text-xl font-bold">
              1
            </div>
            <div>
              <p class="text-lg text-gray-700">
                Del lenke til appen med gjestene ved ankomst og opplys om registreringsplikt.
              </p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-12 h-12 bg-primary text-white rounded-full flex items-center justify-center text-xl font-bold">
              2
            </div>
            <div>
              <p class="text-lg text-gray-700">
                Når turisten avslutter fiskeperioden, får du en e-post. Kontroller og eventuelt korriger fangsten, og godkjenn. Eksportdokumentene sendes automatisk til turisten.
