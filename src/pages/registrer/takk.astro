---
import Layout from '../../layouts/Layout.astro';
import { MINIFINDER } from '../../data/minifinder';
---

<Layout
  title="Takk - export.fish"
  description="Vi har mottatt din henvendelse. Du vil snart motta en e-post med lenke for å fullføre registreringen."
  noindex
>
  <!-- Hero Section -->
  <section class="pt-52 pb-16 bg-gradient-to-br from-blue-50 to-blue-100">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <!-- Success Icon -->
      <div class="mb-6">
        <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto">
          <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
        </div>
      </div>

      <h1 id="takk-title" class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Takk for din interesse!
      </h1>
      <p id="takk-subtitle" class="text-xl text-gray-600 max-w-2xl mx-auto">
        Vi har mottatt henvendelsen din. Sjekk e-posten din for å fullføre registreringen.
      </p>
    </div>
  </section>

  <!-- Content Section -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4">
      <!-- Interest confirmation (default) -->
      <div id="interest-content" class="bg-white rounded-2xl shadow-lg border border-gray-200 p-8 md:p-12">
        <h2 class="text-xl font-semibold text-gray-900 mb-6">Hva skjer nå?</h2>
        <ul class="space-y-6">
          <li class="flex items-start gap-4">
            <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <div>
              <p class="font-medium text-gray-900">Henvendelsen din er mottatt</p>
              <p class="text-sm text-gray-600">Du får straks en e-post med en lenke der du fullfører registreringen av bedriften. Når det er gjort, sender vi dashbord-lenken og QR-koden for turistene, og du er i gang.</p>
            </div>
          </li>
        </ul>

        <!-- Spam notice -->
        <div class="mt-6 pt-6 border-t border-gray-100 bg-amber-50 -mx-4 px-4 py-4 rounded-lg">
          <p class="text-sm text-gray-700">
            <strong class="text-gray-900">Tips:</strong> Sjekk søppelpost/spam-mappen hvis du ikke finner e-posten.
          </p>
        </div>
      </div>

      <!-- Full registration confirmation (shown when ?type=registrert) -->
      <div id="registrert-content" class="hidden bg-white rounded-2xl shadow-lg border border-gray-200 p-8 md:p-12">
        <h2 class="text-xl font-semibold text-gray-900 mb-6">Hva skjer nå?</h2>
        <ul class="space-y-6">
          <li class="flex items-start gap-4">
            <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <div>
              <p class="font-medium text-gray-900">Kontoen din er klar</p>
              <p class="text-sm text-gray-600">Vi har opprettet kontoen din, og dashbord-lenken og QR-koden er sendt til e-posten din.</p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <div class="w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <span class="text-primary font-semibold text-sm">1</span>
            </div>
            <div>
              <p class="font-medium text-gray-900">Del din unike lenke med turistene</p>
              <p class="text-sm text-gray-600">Del ditt export.fish-subdomene og QR-koden med turistene, slik at de kan registrere fangst selv.</p>
            </div>
          </li>
        </ul>

        <!-- Spam notice -->
        <div class="mt-6 pt-6 border-t border-gray-100 bg-amber-50 -mx-4 px-4 py-4 rounded-lg">
          <p class="text-sm text-gray-700">
            <strong class="text-gray-900">Tips:</strong> Sjekk søppelpost/spam-mappen hvis du ikke finner e-post fra oss.
          </p>
        </div>
      </div>

      <!-- Facebook follow card -->
      <div class="mt-8 bg-white rounded-2xl shadow-lg border border-gray-200 p-8 md:p-12 text-center">
        <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-blue-600" aria-hidden="true">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </div>
        <h2 class="text-xl font-semibold text-gray-900 mb-3">Følg oss på Facebook</h2>
        <p class="text-gray-600 mb-6">
          Hold deg oppdatert på regelendringer, tips og nye funksjoner i export.fish.
        </p>
        <a
          href="https://www.facebook.com/profile.php?id=61576429696153"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-lg transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4" aria-hidden="true">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
          Følg oss på Facebook
        </a>
      </div>

      <!-- Minifinder partnerfordel-kort -->
      <div class="mt-8 bg-gradient-to-br from-blue-50 to-blue-100 rounded-2xl shadow-lg border border-blue-200 p-8 md:p-10">
        <div class="flex flex-col md:flex-row md:items-start gap-5">
          <!-- Ikon -->
          <div class="flex-shrink-0 flex flex-col items-center md:items-start gap-2">
            <div class="inline-flex items-center gap-1.5 bg-blue-100 text-blue-700 text-xs font-semibold px-2.5 py-1 rounded-full">
              Partnerfordel
            </div>
            <div class="w-12 h-12 bg-primary text-white rounded-full flex items-center justify-center">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
          </div>

          <!-- Innhold -->
          <div class="flex-1">
            <h2 class="text-xl font-bold text-gray-900 mb-2">
              GPS-sporing for båten, med {MINIFINDER.discountPercent}% rabatt
            </h2>
            <p class="text-gray-700 text-sm leading-relaxed mb-3">
              Som ny export.fish-kunde får du {MINIFINDER.discountPercent}% rabatt på hele Minifinder-sortimentet. Vi anbefaler {MINIFINDER.boatProducts.join(' og ')} for båt. Tyverisikring og sanntidssporing direkte på telefonen.
            </p>

            <!-- Rabattkode -->
            <div class="bg-white rounded-lg border border-blue-200 px-4 py-3 mb-5 inline-block">
              <p class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-0.5">Din rabattkode</p>
              <p class="text-xl font-mono font-bold text-primary tracking-widest">{MINIFINDER.discountCode}</p>
              <p class="text-xs text-gray-500 mt-0.5">Oppgi koden i kassen på minifinder.com</p>
            </div>

            <!-- CTAer -->
            <div class="flex flex-col sm:flex-row gap-3">
              <a
                href="/partnere/minifinder"
                class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-hover text-white font-semibold px-5 py-2.5 rounded-lg transition-colors text-sm"
              >
                Les mer om tilbudet
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
              <a
                href={MINIFINDER.getUrlWithUtm('takk-side')}
                target="_blank"
                rel="sponsored noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 bg-white hover:bg-gray-50 text-primary border border-primary font-semibold px-5 py-2.5 rounded-lg transition-colors text-sm"
              >
                Gå til Minifinder
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact info -->
      <div class="mt-12 text-center">
        <p class="text-gray-600 mb-6">
          Har du spørsmål i mellomtiden?
        </p>
        <a
          href="/kontakt"
          class="inline-flex items-center gap-2 bg-primary hover:bg-primary-hover text-white font-semibold py-3 px-6 rounded-lg transition-colors"
        >
          Kontakt oss
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const urlParams = new URLSearchParams(window.location.search);
  const type = urlParams.get('type');

  if (type === 'registrert') {
    // Show full registration confirmation
    const title = document.getElementById('takk-title');
    const subtitle = document.getElementById('takk-subtitle');
    const interestContent = document.getElementById('interest-content');
    const registrertContent = document.getElementById('registrert-content');

    if (title) title.textContent = 'Bedriften din er registrert!';
    if (subtitle) subtitle.textContent = 'Takk for at du valgte export.fish. Kontoen din er klar til bruk.';
    if (interestContent) interestContent.classList.add('hidden');
    if (registrertContent) registrertContent.classList.remove('hidden');
  }
</script>
